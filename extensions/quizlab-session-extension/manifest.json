{
  "manifest_version": 3,
  "name": "Quizlab Google Session Bridge",
  "version": "1.0.0",
  "description": "Shares Google session cookies with Quizlab Reader for AI workspace access.",
  "permissions": ["cookies", "alarms", "storage"],
  "host_permissions": ["https://*.google.com/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
