{
    "compilerOptions": {
        "baseUrl": ".",
        // Path aliases (renderer + shared-core)
        "paths": {
            "@app/*": [
                "./src/app/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ],
            "@shared-core/*": [
                "./shared/*"
            ],
            "@electron/*": [
                "./electron/*"
            ],
            "@ui/*": [
                "./src/shared/ui/*"
            ],
            "@features/*": [
                "./src/features/*"
            ],
            "@platform/*": [
                "./src/platform/*"
            ]
        }
    },
    "files": [],
    "references": [
        {
            "path": "./tsconfig.app.json"
        },
        {
            "path": "./tsconfig.node.json"
        }
    ]
}
