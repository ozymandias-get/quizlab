{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": "./.cache/tsconfig.node.test.tsbuildinfo"
  },
  "include": ["electron/**/*", "shared/**/*", "src/shared/lib/logger.ts"],
  "exclude": [
    "dist/**/*",
    "dist-electron/**/*",
    "release/**/*",
    "coverage/**/*",
    ".cache/**/*",
    "node_modules/**/*"
  ]
}
