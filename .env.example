# Quizlab Reader Environment Variables Configuration Template
# Rename this file to .env or .env.local to customize the settings locally.
# DO NOT commit real secrets or credentials to the repository.

# ==========================================
# 1. Window & Application Configuration
# ==========================================

# Allow launching multiple instances of the application (1 = Enabled, 0 = Disabled)
# Default: 0 (Single-instance lock is active by default)
APP_ALLOW_MULTI_INSTANCE=0

# Override the renderer web view URL for development purposes
# Default: http://localhost:5173
APP_RENDERER_URL=http://localhost:5173

# Open Chrome DevTools automatically upon startup (1 = Enabled, 0 = Disabled)
# Default: 0
APP_OPEN_DEVTOOLS=0


# ==========================================
# 2. Gemini Web Session Configuration
# ==========================================

# NOTE: GEMINI_WEB_SESSION_ENABLED has been removed — the feature is always on.

# Enable Gemini web sessions automatically for new users (true/false)
# Default: true
GEMINI_WEB_SESSION_DEFAULT_ENABLED=true

# Timeout (in milliseconds) for the initial Google sign-in flow
# Minimum: 300,000 (5 minutes), Maximum: 43,200,000 (12 hours)
# Default: 7,200,000 (2 hours)
GEMINI_WEB_LOGIN_TIMEOUT_MS=7200000

# Health check interval for validating Google login and cookie fresh state (in milliseconds)
# Minimum: 60,000 (1 minute), Maximum: 3,600,000 (1 hour)
# Default: 300,000 (5 minutes)
GEMINI_WEB_CHECK_INTERVAL_MS=300000

# Random jitter percentage added to the check interval to avoid synchronized network requests
# Range: 0 to 50
# Default: 10
GEMINI_WEB_CHECK_JITTER_PCT=10

# Delay before retrying after a failed background session health check (in milliseconds)
# Minimum: 10,000 (10 seconds), Maximum: 600,000 (10 minutes)
# Default: 30,000 (30 seconds)
GEMINI_WEB_RETRY_DELAY_MS=30000

# Maximum consecutive failures allowed before transitioning state to degraded or auth_required
# Range: 1 to 5
# Default: 2
GEMINI_WEB_MAX_CONSECUTIVE_FAILURES=2

# Playwright browser automation wait-for-networkidle timeout (in milliseconds)
# Minimum: 5,000 (5 seconds), Maximum: 20,000 (20 seconds)
# Default: 12,000 (12 seconds)
GEMINI_WEB_NETWORKIDLE_TIMEOUT_MS=12000


# ==========================================
# 3. Silent & Headless Refresh Configuration
# ==========================================

# Timeout for silent cookie refreshing inside Chromium partition (in milliseconds)
# Minimum: 10,000 (10 seconds), Maximum: 120,000 (2 minutes)
# Default: 25,000 (25 seconds)
GEMINI_WEB_SILENT_REFRESH_TIMEOUT_MS=25000

# Cooldown period between silent cookie refresh attempts (in milliseconds)
# Minimum: 60,000 (1 minute), Maximum: 3,600,000 (1 hour)
# Default: 600,000 (10 minutes)
GEMINI_WEB_SILENT_REFRESH_COOLDOWN_MS=600000

# Timeout for headless browser-based token refresh attempts (in milliseconds)
# Minimum: 10,000 (10 seconds), Maximum: 180,000 (3 minutes)
# Default: 45,000 (45 seconds)
GEMINI_WEB_HEADLESS_REFRESH_TIMEOUT_MS=45000

# Cooldown period between headless browser refresh attempts (in milliseconds)
# Minimum: 60,000 (1 minute), Maximum: 7,200,000 (2 hours)
# Default: 900,000 (15 minutes)
GEMINI_WEB_HEADLESS_REFRESH_COOLDOWN_MS=900000

# Grace period after a refresh attempt before checking state again (in milliseconds)
# Minimum: 1,000 (1 second), Maximum: 30,000 (30 seconds)
# Default: 5000
GEMINI_WEB_REFRESH_GRACE_PERIOD_MS=5000

# Cookie age threshold that triggers a silent background refresh (in milliseconds)
# Minimum: 60,000 (1 minute), Maximum: 3,600,000 (1 hour)
# Default: 300,000 (5 minutes)
GEMINI_WEB_COOKIE_REFRESH_THRESHOLD_MS=300000


# ==========================================
# 4. Chrome Extension Bridge Configuration
# ==========================================

# Port for the local HTTP bridge server used by the Chrome extension
# Default: 51999
QUIZLAB_EXTENSION_BRIDGE_PORT=51999
