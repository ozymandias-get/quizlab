{
    "name": "quizlab-reader",
    "version": "2.2.4",
    "description": "The Ultimate AI-Powered PDF Reader & Quiz Generator. Study faster with split-screen PDF viewing, Google Gemini AI integration, and automatic flashcard creation.",
    "main": "dist/electron/electron/app/index.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/ozymandias-get/quizlab.git"
    },
    "scripts": {
        "dev": "node scripts/dev.mjs",
        "dev:web": "vite",
        "dev:electron": "npm run build:backend && wait-on http://localhost:5173 && electron .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "typecheck": "tsc -b",
        "lint": "eslint . --max-warnings=0",
        "audit:high": "npm audit --audit-level=high",
        "analyze": "vite-bundle-visualizer",
        "build:backend": "tsc -b tsconfig.node.json --force",
        "build:renderer:web": "vite build",
        "build:renderer:electron": "node scripts/build-electron.mjs",
        "build:web": "tsc && npm run build:renderer:web",
        "build": "tsc && npm run build:renderer:electron && npm run build:backend",
        "build:win": "npm run build && electron-builder --win",
        "build:mac": "npm run build && electron-builder --mac",
        "build:linux": "npm run build && electron-builder --linux",
        "preview": "vite preview",
        "tag:push": "powershell -Command \"$v=(Get-Content package.json | ConvertFrom-Json).version; git tag | ForEach-Object { git tag -d $_; git push origin --delete $_ }; git tag $v; git push origin $v\""
    },
    "build": {
        "appId": "com.quizlab.reader",
        "productName": "Quizlab Reader",
        "copyright": "Copyright (c) 2026 Quizlab Reader",
        "directories": {
            "output": "release",
            "buildResources": "resources"
        },
        "files": [
            "dist/**/*",
            "resources/**/*"
        ],
        "extraResources": [
            {
                "from": "resources/",
                "to": "resources/",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "resources/icon.ico",
            "artifactName": "QuizlabReader-Setup-${version}.${ext}",
            "signAndEditExecutable": false,
            "forceCodeSigning": false
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "allowElevation": true,
            "installerIcon": "resources/icon.ico",
            "uninstallerIcon": "resources/icon.ico",
            "installerHeaderIcon": "resources/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Quizlab Reader",
            "include": "installer/installer.nsh",
            "installerLanguages": [
                "en_US",
                "tr_TR"
            ],
            "language": "1033",
            "warningsAsErrors": false,
            "runAfterFinish": true,
            "deleteAppDataOnUninstall": false
        },
        "mac": {
            "target": "dmg",
            "icon": "resources/icon.png",
            "category": "public.app-category.productivity"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "resources/icon.png",
            "category": "Office"
        },
        "publish": {
            "provider": "github",
            "owner": "ozymandias-get",
            "repo": "quizlab",
            "releaseType": "release"
        },
        "npmRebuild": false,
        "nodeGypRebuild": false
    },
    "keywords": [
        "electron",
        "react",
        "pdf-viewer",
        "ai-assistant",
        "study-tool",
        "quiz-generator",
        "flashcards",
        "gemini-ai",
        "education",
        "exam-prep",
        "active-recall",
        "pdf-annotation",
        "typescript",
        "vite"
    ],
    "author": "ozymandias-get",
    "license": "MIT",
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.2.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.46.1",
        "@typescript-eslint/parser": "^8.46.1",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/coverage-v8": "^4.0.18",
        "autoprefixer": "^10.4.16",
        "electron": "^40.6.1",
        "electron-builder": "^26.7.0",
        "eslint": "^8.57.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-electron": "^7.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.24",
        "eslint-plugin-security": "^4.0.0",
        "globals": "^17.3.0",
        "jsdom": "^28.1.0",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "vite-bundle-visualizer": "^1.2.1",
        "vitest": "^4.0.18",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.9",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@react-pdf-viewer/core": "^3.12.0",
        "@react-pdf-viewer/page-navigation": "^3.12.0",
        "@react-pdf-viewer/scroll-mode": "^3.12.0",
        "@react-pdf-viewer/search": "^3.12.0",
        "@react-pdf-viewer/zoom": "^3.12.0",
        "@rollup/plugin-terser": "^0.1.0",
        "@tanstack/react-query": "^5.90.21",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dompurify": "^3.3.1",
        "framer-motion": "^12.34.0",
        "lucide-react": "^0.563.0",
        "pdfjs-dist": "3.11.174",
        "playwright-core": "^1.58.2",
        "postcss-import": "^16.1.1",
        "react": "^19.2.4",
        "react-colorful": "^5.6.1",
        "react-dom": "^19.2.4",
        "react-virtuoso": "^4.18.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "tar": "^7.5.9",
        "zustand": "^5.0.11"
    },
    "overrides": {
        "@rollup/plugin-terser": {
            "serialize-javascript": "^7.0.3"
        },
        "rollup-plugin-terser": {
            "serialize-javascript": "^7.0.3"
        }
    }
}
