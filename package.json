{
  "name": "quizlab-reader",
  "version": "4.0.2",
  "private": true,
  "description": "AI-powered PDF reader with a split-screen workspace: read documents alongside ChatGPT, Gemini, Claude, and more via embedded webviews, automation, and local-first privacy.",
  "main": "dist/electron/electron/app/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozymandias-get/quizlab.git"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:electron": "npm run build:backend && wait-on http://localhost:5173 && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:check-hygiene": "node scripts/check-repo-hygiene.mjs",
    "ci:check-version": "node scripts/check-version-consistency.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings=596",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:high": "npm audit --audit-level=high",
    "analyze": "vite-bundle-visualizer",
    "analyze:bundle": "vite-bundle-visualizer",
    "analyze:knip": "knip",
    "analyze:prune": "ts-prune",
    "analyze:deadcode": "npm run analyze:knip && npm run analyze:prune",
    "analyze:duplicates": "jscpd --reporters console",
    "analyze:circular": "madge --circular --extensions ts,tsx,js,jsx src/ electron/ shared/",
    "analyze:architecture": "depcruise --config .dependency-cruiser.cjs --output-type text --do-not-follow 'node_modules' src electron shared",
    "analyze:imports": "eslint . --max-warnings=9999 --rule '{\"unused-imports/no-unused-imports\": \"warn\", \"unused-imports/no-unused-vars\": [\"warn\", {\"vars\": \"all\", \"varsIgnorePattern\": \"^_\", \"args\": \"after-used\", \"argsIgnorePattern\": \"^_\"}]}'",
    "analyze:security": "semgrep --config .semgrep.yml src/ electron/ shared/ && npm audit --audit-level=high",
    "analyze:types": "type-coverage --strict --project tsconfig.app.json --detail --ignore-files '**/*.test.*' --ignore-files '**/*.spec.*' --ignore-files '**/__tests__/**'",
    "analyze:types:ci": "node scripts/check-type-coverage.mjs",
    "analyze:mutation": "stryker run",
    "analyze:electron": "electronegativity -i . -o reports/electron-security/analysis.txt",
    "analyze:css": "stylelint 'src/**/*.css' 'electron/**/*.css'",
    "analyze:spell": "cspell --no-progress --show-context 'src/**/*.{ts,tsx}' 'electron/**/*.{ts,tsx}' 'shared/**/*.ts'",
    "analyze:spell:ci": "cspell --no-progress --show-context --no-exit-code 'src/**/*.{ts,tsx}' 'electron/**/*.{ts,tsx}' 'shared/**/*.ts'",
    "analyze:file-sizes": "node scripts/check-file-sizes.mjs",
    "commitlint": "commitlint --edit",
    "analyze:sonar": "eslint . --max-warnings=9999 --plugin sonarjs",
    "analyze:all": "npm run analyze:deadcode && npm run analyze:duplicates && npm run analyze:circular && npm run analyze:architecture && npm run analyze:security && npm run analyze:types && npm run analyze:electron && npm run analyze:bundle",
    "build:backend": "tsc -b tsconfig.node.json --force && esbuild electron/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/electron/electron/preload/index.js --external:electron",
    "build:renderer:web": "vite build",
    "build:renderer:electron": "node scripts/build-electron.mjs",
    "build:web": "tsc -b && npm run build:renderer:web",
    "build": "tsc -b && npm run build:renderer:electron && npm run build:backend",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.quizlab.reader",
    "productName": "Quizlab Reader",
    "copyright": "Copyright (c) 2026 Quizlab Reader",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "extensions/",
        "to": "extensions/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "QuizlabReader-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quizlab Reader",
      "include": "installer/installer.nsh",
      "installerLanguages": [
        "en_US",
        "tr_TR"
      ],
      "language": "1033",
      "warningsAsErrors": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png",
      "category": "Office",
      "maintainer": "ozymandias-get@users.noreply.github.com"
    },
    "publish": {
      "provider": "github",
      "owner": "ozymandias-get",
      "repo": "quizlab",
      "releaseType": "release"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  },
  "keywords": [
    "electron",
    "react",
    "pdf-viewer",
    "ai-assistant",
    "study-tool",
    "gemini-ai",
    "education",
    "exam-prep",
    "active-recall",
    "pdf-annotation",
    "typescript",
    "vite"
  ],
  "author": "ozymandias-get",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@doyensec/electronegativity": "^1.10.3",
    "@stryker-mutator/core": "^9.6.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "cspell": "^10.0.1",
    "dependency-cruiser": "^17.4.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-electron": "^7.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.0",
    "jsdom": "^28.1.0",
    "knip": "^6.18.0",
    "lint-staged": "^16.3.3",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.11.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.3.0",
    "ts-prune": "^0.10.3",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@radix-ui/react-slider": "^1.4.1",
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/page-navigation": "^3.12.0",
    "@react-pdf-viewer/search": "^3.12.0",
    "@react-pdf-viewer/zoom": "^3.12.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.1",
    "@tsparticles/engine": "^4.2.1",
    "@tsparticles/react": "^4.2.1",
    "@tsparticles/slim": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.2",
    "lucide-react": "^0.563.0",
    "motion": "^12.41.0",
    "pdfjs-dist": "3.11.174",
    "radix-ui": "^1.6.0",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "yauzl": ">=3.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write",
    "*.{ts,tsx,js,jsx}": "eslint --fix"
  }
}
