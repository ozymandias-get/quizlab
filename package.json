{
  "name": "quizlab-reader",
  "version": "3.0.6",
  "description": "AI-powered PDF reader with a split-screen workspace: read documents alongside ChatGPT, Gemini, Claude, and more via embedded webviews, automation, and local-first privacy.",
  "main": "dist/electron/electron/app/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozymandias-get/quizlab.git"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:electron": "npm run build:backend && wait-on http://localhost:5173 && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "ci:check-hygiene": "node scripts/check-repo-hygiene.mjs",
    "ci:check-version": "node scripts/check-version-consistency.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:high": "npm audit --audit-level=high",
    "analyze": "vite-bundle-visualizer",
    "build:backend": "tsc -b tsconfig.node.json --force",
    "build:renderer:web": "vite build",
    "build:renderer:electron": "node scripts/build-electron.mjs",
    "build:web": "tsc -b && npm run build:renderer:web",
    "build": "tsc -b && npm run build:renderer:electron && npm run build:backend",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview",
    "tag:push": "powershell -Command \"$v='v' + (Get-Content package.json | ConvertFrom-Json).version; git tag | ForEach-Object { git tag -d $_; git push origin --delete $_ }; git tag $v; git push origin $v\"",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.quizlab.reader",
    "productName": "Quizlab Reader",
    "copyright": "Copyright (c) 2026 Quizlab Reader",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "QuizlabReader-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quizlab Reader",
      "include": "installer/installer.nsh",
      "installerLanguages": [
        "en_US",
        "tr_TR"
      ],
      "language": "1033",
      "warningsAsErrors": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png",
      "category": "Office",
      "maintainer": "ozymandias-get@users.noreply.github.com"
    },
    "publish": {
      "provider": "github",
      "owner": "ozymandias-get",
      "repo": "quizlab",
      "releaseType": "release"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  },
  "keywords": [
    "electron",
    "react",
    "pdf-viewer",
    "ai-assistant",
    "study-tool",
    "gemini-ai",
    "education",
    "exam-prep",
    "active-recall",
    "pdf-annotation",
    "typescript",
    "vite"
  ],
  "author": "ozymandias-get",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "electron": "^40.6.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-electron": "^7.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/page-navigation": "^3.12.0",
    "@react-pdf-viewer/scroll-mode": "^3.12.0",
    "@react-pdf-viewer/search": "^3.12.0",
    "@react-pdf-viewer/zoom": "^3.12.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "pdfjs-dist": "3.11.174",
    "playwright-core": "^1.58.2",
    "postcss-import": "^16.1.1",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tar": "7.5.11",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "@rollup/plugin-terser": {
      "serialize-javascript": "^7.0.3"
    },
    "rollup-plugin-terser": {
      "serialize-javascript": "^7.0.3"
    },
    "tar": "7.5.11",
    "yauzl": ">=3.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write",
    "*.{ts,tsx,js,jsx}": "eslint --fix"
  }
}
